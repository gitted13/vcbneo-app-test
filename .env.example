# Copy file này thành .env và điền giá trị thực
# cp .env.example .env

# Port expose ra ngoài (mặc định 80)
PORT=80

# CORS — thay bằng IP hoặc domain thực của server
CORS_ORIGINS=["http://localhost","http://YOUR_SERVER_IP"]

# ── Database ──────────────────────────────────────────────────────────────────
# Tên database sẽ được tạo tự động khi backend khởi động lần đầu
DB_NAME=vcbneo

# SA password — dùng để SQL Server khởi động và tạo DB/user lần đầu
# Phải đủ mạnh: chữ hoa + thường + số + ký tự đặc biệt, tối thiểu 8 ký tự
SA_PASSWORD=Sa@VCBNeo2026!

# App user — backend dùng user này để kết nối DB hàng ngày (không phải sa)
# User và password được tạo tự động lần đầu khởi động
DB_PASSWORD=App@VCBNeo2026!

# Login thông tin kết nối DB (để tham khảo / dùng SSMS hoặc tool khác kết nối vào):
#   Server : localhost,1433  (nếu expose port) hoặc tên container "db"
#   Database: vcbneo
#   Login   : vcbneo_app
#   Password: (giá trị DB_PASSWORD ở trên)
