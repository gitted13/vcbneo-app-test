# Copy file này thành .env và điền giá trị thực
# cp .env.example .env

# Port expose ra ngoài (mặc định 80)
PORT=80

# Danh sách domain được phép gọi API (CORS)
# Thay yourdomain.com bằng domain thực của bạn
CORS_ORIGINS=["http://localhost","https://yourdomain.com"]

# Database
# Tên database trong SQL Server (sẽ được tạo tự động nếu chưa có)
DB_NAME=vcbneo

# Mật khẩu SA cho SQL Server — phải đủ mạnh (chữ hoa + thường + số + ký tự đặc biệt)
# SQL Server Express yêu cầu tối thiểu 8 ký tự
DB_PASSWORD=VCBNeo@2026!
